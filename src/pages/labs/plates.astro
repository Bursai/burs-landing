---
// src/pages/labs/plates.astro
// Concept 01 — Editorial Plates. A pinned stage; the five screens hang as
// matted exhibition plates on a wall that glides horizontally with scroll.
// The caption column bottom-left trades copy as each plate crosses center.
import Base from "../../layouts/Base.astro";
import LabHeader from "./_LabHeader.astro";
import { labActs } from "./_data";
---
<Base
  title="Lab 01 — Editorial Plates"
  description="Showcase concept: app screens as matted exhibition plates in a pinned horizontal gallery."
  path="/labs/plates"
>
  <meta slot="head" name="robots" content="noindex,nofollow" />
  <LabHeader n={1} name="Editorial Plates" concept="Pinned horizontal gallery — screens as matted exhibition plates" />

  <section class="plates" data-plates>
    <div class="plates__stage">
      <div class="plates__head wrap">
        <p class="eyebrow">THE APP — IN FIVE PLATES</p>
        <p class="plates__counter"><span data-plates-counter>01</span> — 05</p>
      </div>

      <div class="plates__track" data-plates-track>
        {labActs.map((a, i) => (
          <figure class="plate" data-plate={a.index} class:list={[i === 0 && "is-on"]}>
            <figcaption class="plate__mat-head">
              <span class="plate__numeral">{a.numeral}</span>
              <span class="plate__label">{a.eyebrow}</span>
            </figcaption>
            <div class="plate__img">
              <img src={a.image} alt={a.imageAlt} loading="eager" decoding="async" />
            </div>
          </figure>
        ))}
      </div>

      <div class="plates__copy wrap">
        {labActs.map((a, i) => (
          <div class="plates__cap" data-plate-copy={a.index} class:list={[i === 0 && "is-on"]}>
            <h2 set:html={a.headline} />
            <p class="lede">{a.lede}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .plates{ height: 460vh; background: var(--cream); position: relative }
  .plates__stage{
    position: sticky; top: 0; height: 100vh; overflow: hidden;
    display: flex; flex-direction: column; justify-content: center;
  }

  .plates__head{
    position: absolute; top: clamp(20px, 4vh, 44px); left: 0; right: 0;
    display: flex; justify-content: space-between; align-items: baseline;
  }
  .plates__head .eyebrow{ color: var(--gold-deep) }
  .plates__counter{ font-family: var(--mono); font-size: 11px; letter-spacing: .3em; color: var(--charcoal-2) }
  .plates__counter span{ color: var(--gold-deep) }

  .plates__track{
    display: flex; align-items: center;
    gap: clamp(36px, 5vw, 96px);
    padding-inline: 50vw;             /* lets first/last plate reach center */
    width: max-content;
    will-change: transform;
  }

  .plate{
    margin: 0;
    background: var(--cream-paper);
    border: 1px solid rgba(28,25,23,.14);
    box-shadow: 0 30px 60px -28px rgba(14,13,12,.4);
    padding: clamp(12px, 1.4vw, 20px);
    transition: transform .5s var(--eo), opacity .5s var(--eo);
    transform: scale(.93);
    opacity: .55;
  }
  .plate.is-on{ transform: scale(1); opacity: 1 }

  .plate__mat-head{
    display: flex; align-items: baseline; justify-content: space-between; gap: 18px;
    padding: 2px 4px 12px;
  }
  .plate__numeral{
    font-family: var(--display); font-weight: 200; font-style: italic;
    font-size: 26px; color: var(--gold-deep); line-height: 1;
  }
  .plate__label{
    font-family: var(--mono); font-size: 9px; letter-spacing: .25em;
    text-transform: uppercase; color: var(--charcoal-2);
  }
  .plate__img{
    height: min(56vh, 560px);
    aspect-ratio: 1320 / 2868;
    overflow: hidden;
    border: 1px solid rgba(28,25,23,.18);
  }
  .plate__img img{ width: 100%; height: 100%; object-fit: cover; display: block }

  .plates__copy{
    position: absolute; left: 0; right: 0;
    bottom: clamp(22px, 5vh, 56px);
    pointer-events: none;
  }
  .plates__cap{
    position: absolute; bottom: 0; left: var(--gutter);
    max-width: 44ch;
    opacity: 0; transform: translateY(14px);
    transition: opacity .45s var(--eo), transform .45s var(--eo);
  }
  .plates__cap.is-on{ opacity: 1; transform: translateY(0) }
  .plates__cap h2{
    margin: 0;
    font-family: var(--display); font-weight: 300; letter-spacing: -.03em; line-height: 1.02;
    font-size: clamp(26px, 2.9vw, 44px); color: var(--charcoal); text-wrap: balance;
  }
  .plates__cap h2 :global(em){ font-style: italic; color: var(--gold) }
  .plates__cap .lede{
    margin-top: 10px;
    font-family: var(--serif); font-style: italic;
    font-size: 15px; line-height: 1.5; color: var(--charcoal-2);
    max-width: 50ch;
  }

  @media (max-width: 700px){
    .plate__img{ height: 52vh }
    .plates__cap h2{ font-size: 24px }
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>('[data-plates]');
  const track = document.querySelector<HTMLElement>('[data-plates-track]');
  const counter = document.querySelector<HTMLElement>('[data-plates-counter]');
  const plates = [...document.querySelectorAll<HTMLElement>('[data-plate]')];
  const caps = [...document.querySelectorAll<HTMLElement>('[data-plate-copy]')];

  if (section && track && plates.length) {
    let active = '1';

    const render = () => {
      const total = section.offsetHeight - window.innerHeight;
      const p = total > 0 ? Math.min(1, Math.max(0, -section.getBoundingClientRect().top / total)) : 0;
      const range = track.scrollWidth - window.innerWidth;
      track.style.transform = `translate3d(${-p * range}px,0,0)`;

      // Active plate = the one nearest the viewport center line
      const mid = window.innerWidth / 2;
      let best = active, bestD = Infinity;
      plates.forEach(pl => {
        const r = pl.getBoundingClientRect();
        const d = Math.abs((r.left + r.right) / 2 - mid);
        if (d < bestD) { bestD = d; best = pl.dataset.plate!; }
      });
      if (best !== active) {
        active = best;
        if (counter) counter.textContent = active.padStart(2, '0');
      }
      plates.forEach(pl => pl.classList.toggle('is-on', pl.dataset.plate === active));
      caps.forEach(c => c.classList.toggle('is-on', c.dataset.plateCopy === active));
    };

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { ticking = false; render(); });
    };

    render();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
  }
</script>
