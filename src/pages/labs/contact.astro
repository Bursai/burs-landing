---
// src/pages/labs/contact.astro
// Concept 04 — Contact Sheet. All five screens sit in a photographer's
// contact strip along the bottom; a gold viewfinder slides across the strip
// as you scroll and the chosen frame fills the stage above. Frames are
// clickable shortcuts.
import Base from "../../layouts/Base.astro";
import LabHeader from "./_LabHeader.astro";
import { labActs } from "./_data";
---
<Base
  title="Lab 04 — Contact Sheet"
  description="Showcase concept: app screens on a film contact sheet with a sliding gold viewfinder."
  path="/labs/contact"
>
  <meta slot="head" name="robots" content="noindex,nofollow" />
  <LabHeader n={4} name="Contact Sheet" concept="Film contact strip + sliding viewfinder; chosen frame fills the stage" />

  <section class="sheet" data-sheet>
    <div class="sheet__stage">
      <!-- Copy, top-left -->
      <div class="sheet__copy wrap">
        {labActs.map((a, i) => (
          <div class="sheet__cap" data-sheet-copy={a.index} class:list={[i === 0 && "is-on"]}>
            <p class="eyebrow">{a.eyebrow}</p>
            <h2 set:html={a.headline} />
            <p class="lede">{a.lede}</p>
          </div>
        ))}
      </div>

      <!-- The enlargement under the loupe -->
      <div class="sheet__big" aria-hidden="true">
        {labActs.map((a, i) => (
          <img
            src={a.image}
            alt={a.imageAlt}
            data-sheet-big={a.index}
            class:list={[i === 0 && "is-active"]}
            loading="eager"
            decoding="async"
          />
        ))}
      </div>

      <!-- Contact strip -->
      <div class="sheet__strip-row">
        <div class="sheet__strip" data-sheet-strip>
          <div class="sheet__finder" data-sheet-finder aria-hidden="true"></div>
          {labActs.map(a => (
            <button class="sheet__thumb" data-sheet-thumb={a.index} aria-label={`Go to act ${a.numeral}`}>
              <img src={a.image} alt="" loading="eager" decoding="async" />
              <span>{a.numeral}</span>
            </button>
          ))}
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .sheet{ height: 520vh; background: var(--charcoal); position: relative }
  .sheet__stage{ position: sticky; top: 0; height: 100vh; overflow: hidden }

  .sheet__copy{ position: absolute; top: clamp(64px, 11vh, 120px); left: 0; right: 0; z-index: 3; pointer-events: none }
  .sheet__cap{
    position: absolute; top: 0; left: var(--gutter);
    max-width: 36ch;
    opacity: 0; transform: translateY(12px);
    transition: opacity .45s var(--eo), transform .45s var(--eo);
  }
  .sheet__cap.is-on{ opacity: 1; transform: translateY(0) }
  .sheet__cap .eyebrow{ color: var(--gold-bright); margin-bottom: 12px }
  .sheet__cap h2{
    margin: 0;
    font-family: var(--display); font-weight: 250; letter-spacing: -.03em; line-height: 1.02;
    font-size: clamp(26px, 2.7vw, 40px); color: var(--cream); text-wrap: balance;
  }
  .sheet__cap h2 :global(em){ font-style: italic; color: var(--gold-bright) }
  .sheet__cap .lede{
    margin-top: 10px;
    font-family: var(--serif); font-style: italic;
    font-size: 15px; line-height: 1.5; color: rgba(245,240,232,.66);
  }

  .sheet__big{
    position: absolute;
    right: clamp(20px, 7vw, 130px);
    top: 50%;
    transform: translateY(-54%);
    height: min(62vh, 620px);
    aspect-ratio: 1320 / 2868;
    border-radius: 22px;
    overflow: hidden;
    border: 1px solid rgba(245,240,232,.2);
    box-shadow: 0 50px 100px -40px rgba(0,0,0,.8);
  }
  .sheet__big img{
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0; z-index: 0;
    transition: opacity .45s var(--eo), transform .9s var(--eo);
    transform: scale(1.04);
    will-change: opacity;
  }
  .sheet__big img.is-prev{ opacity: 1; z-index: 1; transform: scale(1); transition: none }
  .sheet__big img.is-active{ opacity: 1; z-index: 2; transform: scale(1) }

  .sheet__strip-row{
    position: absolute; left: 0; right: 0;
    bottom: clamp(18px, 4.5vh, 48px);
    display: flex; justify-content: center;
    z-index: 4;
  }
  .sheet__strip{
    position: relative;
    display: flex; gap: 14px;
    padding: 14px 18px;
    background: var(--ink);
    border: 1px solid rgba(245,240,232,.14);
    /* film strip sprocket holes */
    background-image:
      radial-gradient(circle, rgba(245,240,232,.18) 2px, transparent 2.6px),
      radial-gradient(circle, rgba(245,240,232,.18) 2px, transparent 2.6px);
    background-size: 22px 6px, 22px 6px;
    background-position: 8px 4px, 8px calc(100% - 4px);
    background-repeat: repeat-x;
  }
  .sheet__thumb{
    position: relative;
    width: clamp(44px, 5.4vw, 66px);
    aspect-ratio: 1320 / 2868;
    padding: 0; border: 1px solid rgba(245,240,232,.16);
    background: none; cursor: pointer;
    overflow: hidden;
    filter: grayscale(.85) brightness(.7);
    transition: filter .4s var(--eo);
  }
  .sheet__thumb img{ width: 100%; height: 100%; object-fit: cover; display: block }
  .sheet__thumb span{
    position: absolute; bottom: 4px; left: 0; right: 0;
    font-family: var(--mono); font-size: 8px; letter-spacing: .2em;
    color: var(--cream); text-shadow: 0 1px 4px rgba(0,0,0,.9);
  }
  .sheet__thumb.is-on{ filter: grayscale(0) brightness(1) }

  /* The gold viewfinder: four corner brackets that glide along the strip */
  .sheet__finder{
    position: absolute;
    top: 8px; bottom: 8px;
    left: 0; width: 60px;            /* JS keeps these matched to the thumb */
    pointer-events: none;
    transition: transform .5s var(--eio), width .3s var(--eo);
    z-index: 2;
  }
  .sheet__finder::before{
    content: '';
    position: absolute; inset: 0;
    background:
      linear-gradient(var(--gold-bright), var(--gold-bright)) top left / 12px 2px,
      linear-gradient(var(--gold-bright), var(--gold-bright)) top left / 2px 12px,
      linear-gradient(var(--gold-bright), var(--gold-bright)) top right / 12px 2px,
      linear-gradient(var(--gold-bright), var(--gold-bright)) top right / 2px 12px,
      linear-gradient(var(--gold-bright), var(--gold-bright)) bottom left / 12px 2px,
      linear-gradient(var(--gold-bright), var(--gold-bright)) bottom left / 2px 12px,
      linear-gradient(var(--gold-bright), var(--gold-bright)) bottom right / 12px 2px,
      linear-gradient(var(--gold-bright), var(--gold-bright)) bottom right / 2px 12px;
    background-repeat: no-repeat;
  }

  @media (max-width: 860px){
    .sheet__big{
      right: 50%; transform: translate(50%, -58%);
      height: 48vh;
    }
    .sheet__cap h2{ font-size: 22px }
    .sheet__cap .lede{ display: none }
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>('[data-sheet]');
  const bigs = [...document.querySelectorAll<HTMLImageElement>('[data-sheet-big]')];
  const caps = [...document.querySelectorAll<HTMLElement>('[data-sheet-copy]')];
  const thumbs = [...document.querySelectorAll<HTMLElement>('[data-sheet-thumb]')];
  const finder = document.querySelector<HTMLElement>('[data-sheet-finder]');
  const strip = document.querySelector<HTMLElement>('[data-sheet-strip]');

  if (section && bigs.length && thumbs.length) {
    const N = bigs.length;
    let active = 1;
    let prev: number | null = null;

    const placeFinder = () => {
      if (!finder || !strip) return;
      const th = thumbs[active - 1];
      const tr = th.getBoundingClientRect();
      const sr = strip.getBoundingClientRect();
      finder.style.width = `${tr.width + 12}px`;
      finder.style.transform = `translateX(${tr.left - sr.left - 6}px)`;
    };

    const apply = () => {
      bigs.forEach(b => {
        const i = Number(b.dataset.sheetBig);
        b.classList.toggle('is-active', i === active);
        b.classList.toggle('is-prev', i === prev);
      });
      caps.forEach(c => c.classList.toggle('is-on', Number(c.dataset.sheetCopy) === active));
      thumbs.forEach(t => t.classList.toggle('is-on', Number(t.dataset.sheetThumb) === active));
      placeFinder();
    };

    const render = () => {
      const total = section.offsetHeight - window.innerHeight;
      const p = total > 0 ? Math.min(1, Math.max(0, -section.getBoundingClientRect().top / total)) : 0;
      const idx = Math.min(N, Math.floor(p * N) + 1);
      if (idx !== active) { prev = active; active = idx; }
      apply();
    };

    // Clicking a frame scrolls to that act's segment of the runway
    thumbs.forEach(t => t.addEventListener('click', () => {
      const i = Number(t.dataset.sheetThumb);
      const total = section.offsetHeight - window.innerHeight;
      const top = section.getBoundingClientRect().top + window.scrollY;
      window.scrollTo({ top: top + ((i - 0.5) / N) * total, behavior: 'smooth' });
    }));

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { ticking = false; render(); });
    };

    render();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
  }
</script>
