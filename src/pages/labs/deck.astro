---
// src/pages/labs/deck.astro
// Concept 02 — Lookbook Deck. The copy scrolls on the left; on the right a
// deck of lookbook cards builds: each act deals a new card onto the pile
// with a settle of rotation, earlier acts fanned beneath.
import Base from "../../layouts/Base.astro";
import LabHeader from "./_LabHeader.astro";
import { labActs } from "./_data";

const tilts = [-2.6, 1.8, -1.2, 2.4, -1.6]; // resting rotation per card
---
<Base
  title="Lab 02 — Lookbook Deck"
  description="Showcase concept: app screens dealt as lookbook cards stacking with scroll."
  path="/labs/deck"
>
  <meta slot="head" name="robots" content="noindex,nofollow" />
  <LabHeader n={2} name="Lookbook Deck" concept="Cards dealt onto a pile, one per act, fanned beneath" />

  <section class="deck">
    <div class="wrap deck__grid">
      <div class="deck__panels">
        {labActs.map(a => (
          <article class="dpanel" data-deck-panel={a.index}>
            <p class="eyebrow">{a.eyebrow}</p>
            <h2 set:html={a.headline} />
            <p class="lede">{a.lede}</p>
          </article>
        ))}
      </div>

      <aside class="deck__stage-col" aria-hidden="true">
        <div class="deck__stage">
          {labActs.map((a, i) => (
            <figure
              class="dcard"
              data-deck-card={a.index}
              class:list={[i === 0 && "is-played"]}
              style={`--tilt:${tilts[i]}deg; z-index:${a.index}`}
            >
              <div class="dcard__img">
                <img src={a.image} alt={a.imageAlt} loading="eager" decoding="async" />
              </div>
              <figcaption class="dcard__band">
                <span class="dcard__numeral">{a.numeral}</span>
                <span class="dcard__label">{a.eyebrow}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </aside>
    </div>
  </section>
</Base>

<style>
  .deck{ background: var(--cream-paper); padding-block: clamp(48px, 6vh, 90px) }
  .deck__grid{
    display: grid; grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 6vw, 96px); align-items: start;
  }

  .deck__panels{ display: flex; flex-direction: column }
  .dpanel{
    min-height: 72vh;
    display: flex; flex-direction: column; justify-content: center;
    padding: clamp(28px, 5vh, 56px) 0;
    border-top: 1px solid rgba(28,25,23,.07);
    transition: opacity .45s var(--eo);
  }
  .dpanel:first-child{ border-top: 0 }
  .dpanel.is-dim{ opacity: .35 }
  .dpanel .eyebrow{ margin-bottom: 18px; color: var(--gold-deep) }
  .dpanel h2{
    margin: 0;
    font-family: var(--display); font-weight: 200; letter-spacing: -.035em; line-height: .94;
    font-size: clamp(36px, 4.6vw, 64px); color: var(--charcoal); text-wrap: balance;
  }
  .dpanel h2 :global(em){ font-style: italic; color: var(--gold); font-weight: 300 }
  .dpanel .lede{
    margin-top: 20px; max-width: 42ch;
    font-family: var(--serif); font-style: italic;
    font-size: var(--t-lede); line-height: 1.5; color: var(--charcoal-2);
  }

  .deck__stage-col{
    position: sticky; top: 0; height: 100vh;
    display: flex; align-items: center; justify-content: center;
  }
  .deck__stage{
    position: relative;
    height: min(62vh, 600px);
    aspect-ratio: 1320 / 2560;       /* card is image + caption band */
  }

  .dcard{
    position: absolute; inset: 0;
    margin: 0;
    background: var(--cream);
    border: 1px solid rgba(28,25,23,.16);
    padding: 10px 10px 0;
    box-shadow: 0 36px 70px -30px rgba(14,13,12,.5);
    display: flex; flex-direction: column;
    /* Waiting below the stage, face tilted, ready to be dealt */
    transform: translateY(116%) rotate(9deg);
    opacity: 0;
    transition: transform .65s var(--eio), opacity .4s var(--eo);
    will-change: transform, opacity;
  }
  .dcard.is-played{
    transform: translateY(0) rotate(var(--tilt));
    opacity: 1;
  }
  /* Cards buried under newer ones ease back a touch so corners peek out */
  .dcard.is-under{ transform: translateY(0) rotate(calc(var(--tilt) * 1.6)) scale(.985) }

  .dcard__img{ flex: 1; overflow: hidden; min-height: 0 }
  .dcard__img img{ width: 100%; height: 100%; object-fit: cover; display: block }
  .dcard__band{
    display: flex; align-items: baseline; gap: 14px;
    padding: 12px 6px;
  }
  .dcard__numeral{
    font-family: var(--display); font-style: italic; font-weight: 200;
    font-size: 22px; line-height: 1; color: var(--gold-deep);
  }
  .dcard__label{
    font-family: var(--mono); font-size: 9px; letter-spacing: .22em;
    text-transform: uppercase; color: var(--charcoal-2);
  }

  @media (max-width: 900px){
    .deck__grid{ grid-template-columns: 1fr }
    .deck__stage-col{ position: relative; height: auto; padding-block: 24px }
    .deck__stage{ height: 56vh }
    .dpanel{ min-height: 60vh }
  }
</style>

<script>
  const cards = [...document.querySelectorAll<HTMLElement>('[data-deck-card]')];
  const panels = [...document.querySelectorAll<HTMLElement>('[data-deck-panel]')];

  if (cards.length && panels.length) {
    let active = 1;

    const apply = () => {
      cards.forEach(c => {
        const i = Number(c.dataset.deckCard);
        c.classList.toggle('is-played', i === active);
        c.classList.toggle('is-under', i < active);
        if (i > active) { c.classList.remove('is-played', 'is-under'); }
      });
      panels.forEach(p => {
        p.classList.toggle('is-dim', Number(p.dataset.deckPanel) !== active);
      });
    };

    const pick = () => {
      const mid = window.innerHeight / 2;
      let best = active, bestD = Infinity, activeD = Infinity;
      panels.forEach(p => {
        const r = p.getBoundingClientRect();
        const d = Math.abs((r.top + r.bottom) / 2 - mid);
        const i = Number(p.dataset.deckPanel);
        if (i === active) activeD = d;
        if (d < bestD) { bestD = d; best = i; }
      });
      if (best !== active && bestD < activeD - 12) active = best;
      apply();
    };

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { ticking = false; pick(); });
    };

    pick();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
  }
</script>
