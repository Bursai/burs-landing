---
// src/components/PriceHangTag.astro
// The price card, hung like a boutique garment tag.
// On entering the viewport: a gold thread draws down, the tag drops onto it
// and swings to rest like a real swing-tag (damped pendulum), then keeps an
// almost imperceptible breathe. Moving the mouse across the tag brushes it
// aside with real pendulum physics — speed, direction and how low you touch
// it all matter — and it swings back to rest on its own. Falls back to the
// static card under no-JS / reduced motion.
import LocalizedPriceCard from "./LocalizedPriceCard.astro";
---
<div class="ptag" data-ptag>
  <div class="ptag__pendulum">
    <span class="ptag__thread" aria-hidden="true"></span>
    <div class="ptag__tag">
      <span class="ptag__eyelet" aria-hidden="true"></span>
      <LocalizedPriceCard />
    </div>
  </div>
</div>

<style>
  .ptag{ --thread-h: clamp(48px, 8vh, 104px) }

  /* The rigid body: thread + tag swing together, pivoting at the thread top */
  .ptag__pendulum{
    width: fit-content;
    display: flex; flex-direction: column; align-items: center;
    transform-origin: 50% 0;
  }

  .ptag__thread{
    display: block;
    width: 1px;
    /* Runs past the card edge into the eyelet (centered at top 12px + 9px) */
    height: calc(var(--thread-h) + 21px);
    margin-bottom: -21px;
    position: relative; z-index: 2;
    background: linear-gradient(180deg, var(--gold-deep), var(--gold));
    transform-origin: top;
  }

  .ptag__tag{
    position: relative;
    /* Hover sway pivots at the eyelet, like a finger flicking the tag */
    transform-origin: 50% 12px;
  }
  .ptag :global(.pc){
    box-shadow: 0 36px 60px -30px rgba(14,13,12,.38);
  }

  /* Brass grommet with a punched hole — the thread shows through the gap */
  .ptag__eyelet{
    position: absolute; top: 12px; left: 50%;
    transform: translateX(-50%);
    width: 18px; height: 18px;
    z-index: 3;
    background: radial-gradient(circle,
      transparent 0 3.5px,
      var(--gold-deep) 4px 6.5px,
      rgba(28,25,23,.28) 7px 7.5px,
      transparent 8px);
  }

  /* ---- Choreography (JS arms, then hangs) ---- */
  .ptag.is-armed .ptag__thread{ transform: scaleY(0) }
  .ptag.is-armed .ptag__tag{ opacity: 0 }

  .ptag.is-hung .ptag__thread{ animation: ptag-thread .55s var(--eo) both }
  .ptag.is-hung .ptag__tag{ animation: ptag-drop .6s .4s var(--eo) both }
  .ptag.is-hung .ptag__pendulum{
    animation:
      ptag-settle 2.7s .45s ease-in-out both,
      ptag-breathe 9s 3.4s ease-in-out infinite;
  }

  /* Mouse brushes are simulated in JS on the tag's own `rotate` channel,
     pivoting at the eyelet — separate from the entrance transforms above. */

  @keyframes ptag-thread{ from{ transform: scaleY(0) } to{ transform: scaleY(1) } }
  @keyframes ptag-drop{
    from{ opacity: 0; transform: translateY(-16px) }
    to{ opacity: 1; transform: translateY(0) }
  }
  /* Damped pendulum settle */
  @keyframes ptag-settle{
    0%{ rotate: 3.6deg }
    24%{ rotate: -2.1deg }
    47%{ rotate: 1.1deg }
    68%{ rotate: -.5deg }
    85%{ rotate: .2deg }
    100%{ rotate: 0deg }
  }
  /* Barely-there ambient motion once at rest */
  @keyframes ptag-breathe{
    0%, 100%{ rotate: 0deg }
    30%{ rotate: .45deg }
    70%{ rotate: -.4deg }
  }

  @media (prefers-reduced-motion: reduce){
    .ptag.is-armed .ptag__thread{ transform: none }
    .ptag.is-armed .ptag__tag{ opacity: 1 }
    .ptag.is-hung .ptag__pendulum,
    .ptag.is-hung .ptag__thread,
    .ptag.is-hung .ptag__tag{ animation: none }
  }
</style>

<script>
  const tags = [...document.querySelectorAll<HTMLElement>('[data-ptag]')];
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (tags.length) {
    // Arm only once JS is live so the no-JS fallback stays fully visible
    tags.forEach(t => t.classList.add('is-armed'));
    const io = new IntersectionObserver((entries) => {
      entries.forEach(en => {
        if (en.isIntersecting) {
          en.target.classList.add('is-hung');
          io.unobserve(en.target);
        }
      });
    }, { threshold: 0.25, rootMargin: '0px 0px -8% 0px' });
    tags.forEach(t => io.observe(t));
  }

  // ---- Brush physics ------------------------------------------------------
  // The tag is a damped pendulum pivoting at its eyelet. Mouse movement
  // across it imparts angular impulses — faster brushes and lower contact
  // points (more leverage) swing it harder; it always swings back to rest.
  if (!reduced) tags.forEach(root => {
    const tag = root.querySelector<HTMLElement>('.ptag__tag');
    if (!tag) return;

    const K = 34;        // spring (s^-2) — ~1Hz natural swing, like a paper tag
    const C = 1.7;       // damping (s^-1) — a few visible oscillations
    const GAIN = 0.12;   // deg/s of impulse per px of brush
    const MAX_W = 60;    // deg/s
    const MAX_A = 12;    // deg

    let theta = 0, omega = 0;
    let lastX: number | null = null;
    let lastT = 0;
    let running = false;

    const step = (now: number) => {
      const dt = Math.min((now - lastT) / 1000, 0.032) || 0.016;
      lastT = now;
      omega += (-K * theta - C * omega) * dt;
      theta += omega * dt;
      tag.style.rotate = `${theta.toFixed(3)}deg`;
      if (Math.abs(theta) < 0.02 && Math.abs(omega) < 0.05) {
        running = false;
        theta = 0; omega = 0;
        tag.style.rotate = '';
        return;
      }
      requestAnimationFrame(step);
    };

    const wake = () => {
      if (running) return;
      running = true;
      lastT = performance.now();
      requestAnimationFrame(step);
    };

    tag.addEventListener('pointerenter', e => { lastX = e.clientX; });
    tag.addEventListener('pointerleave', () => { lastX = null; });
    tag.addEventListener('pointermove', e => {
      if (e.pointerType !== 'mouse') return;
      if (lastX === null) { lastX = e.clientX; return; }
      const dx = e.clientX - lastX;
      lastX = e.clientX;
      if (!dx) return;
      // Leverage: brushing near the bottom edge swings more than at the eyelet
      const r = tag.getBoundingClientRect();
      const lever = Math.min(1, Math.max(0.15, (e.clientY - r.top) / r.height));
      omega = Math.min(MAX_W, Math.max(-MAX_W, omega + dx * GAIN * lever));
      // Hard stop so wild shaking can't wind it past a believable arc
      theta = Math.min(MAX_A, Math.max(-MAX_A, theta));
      wake();
    }, { passive: true });
  });
</script>
