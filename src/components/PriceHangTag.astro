---
// src/components/PriceHangTag.astro
// The price card, hung like a boutique garment tag.
// On entering the viewport: a gold thread draws down, the tag drops onto it
// and swings to rest like a real swing-tag (damped pendulum), then keeps an
// almost imperceptible breathe. Hovering the tag gives it a gentle sway
// around its eyelet. Falls back to the static card under no-JS / reduced
// motion.
import LocalizedPriceCard from "./LocalizedPriceCard.astro";
---
<div class="ptag" data-ptag>
  <div class="ptag__pendulum">
    <span class="ptag__thread" aria-hidden="true"></span>
    <div class="ptag__tag">
      <span class="ptag__eyelet" aria-hidden="true"></span>
      <LocalizedPriceCard />
    </div>
  </div>
</div>

<style>
  .ptag{ --thread-h: clamp(48px, 8vh, 104px) }

  /* The rigid body: thread + tag swing together, pivoting at the thread top */
  .ptag__pendulum{
    width: fit-content;
    display: flex; flex-direction: column; align-items: center;
    transform-origin: 50% 0;
  }

  .ptag__thread{
    display: block;
    width: 1px;
    /* Runs past the card edge into the eyelet (centered at top 12px + 9px) */
    height: calc(var(--thread-h) + 21px);
    margin-bottom: -21px;
    position: relative; z-index: 2;
    background: linear-gradient(180deg, var(--gold-deep), var(--gold));
    transform-origin: top;
  }

  .ptag__tag{
    position: relative;
    /* Hover sway pivots at the eyelet, like a finger flicking the tag */
    transform-origin: 50% 12px;
  }
  .ptag :global(.pc){
    box-shadow: 0 36px 60px -30px rgba(14,13,12,.38);
  }

  /* Brass grommet with a punched hole — the thread shows through the gap */
  .ptag__eyelet{
    position: absolute; top: 12px; left: 50%;
    transform: translateX(-50%);
    width: 18px; height: 18px;
    z-index: 3;
    background: radial-gradient(circle,
      transparent 0 3.5px,
      var(--gold-deep) 4px 6.5px,
      rgba(28,25,23,.28) 7px 7.5px,
      transparent 8px);
  }

  /* ---- Choreography (JS arms, then hangs) ---- */
  .ptag.is-armed .ptag__thread{ transform: scaleY(0) }
  .ptag.is-armed .ptag__tag{ opacity: 0 }

  .ptag.is-hung .ptag__thread{ animation: ptag-thread .55s var(--eo) both }
  .ptag.is-hung .ptag__tag{ animation: ptag-drop .6s .4s var(--eo) both }
  .ptag.is-hung .ptag__pendulum{
    animation:
      ptag-settle 2.7s .45s ease-in-out both,
      ptag-breathe 9s 3.4s ease-in-out infinite;
  }

  /* Hover: a gentle sway around the eyelet (separate `rotate` channel so it
     never fights the entrance transforms) */
  .ptag__tag:hover{ animation: ptag-sway 2.2s ease-in-out infinite }

  @keyframes ptag-thread{ from{ transform: scaleY(0) } to{ transform: scaleY(1) } }
  @keyframes ptag-drop{
    from{ opacity: 0; transform: translateY(-16px) }
    to{ opacity: 1; transform: translateY(0) }
  }
  /* Damped pendulum settle */
  @keyframes ptag-settle{
    0%{ rotate: 3.6deg }
    24%{ rotate: -2.1deg }
    47%{ rotate: 1.1deg }
    68%{ rotate: -.5deg }
    85%{ rotate: .2deg }
    100%{ rotate: 0deg }
  }
  /* Barely-there ambient motion once at rest */
  @keyframes ptag-breathe{
    0%, 100%{ rotate: 0deg }
    30%{ rotate: .45deg }
    70%{ rotate: -.4deg }
  }
  @keyframes ptag-sway{
    0%, 100%{ rotate: 0deg }
    28%{ rotate: 1.3deg }
    75%{ rotate: -1.1deg }
  }

  @media (prefers-reduced-motion: reduce){
    .ptag.is-armed .ptag__thread{ transform: none }
    .ptag.is-armed .ptag__tag{ opacity: 1 }
    .ptag.is-hung .ptag__pendulum,
    .ptag.is-hung .ptag__thread,
    .ptag.is-hung .ptag__tag,
    .ptag__tag:hover{ animation: none }
  }
</style>

<script>
  const tags = [...document.querySelectorAll<HTMLElement>('[data-ptag]')];
  if (tags.length) {
    // Arm only once JS is live so the no-JS fallback stays fully visible
    tags.forEach(t => t.classList.add('is-armed'));
    const io = new IntersectionObserver((entries) => {
      entries.forEach(en => {
        if (en.isIntersecting) {
          en.target.classList.add('is-hung');
          io.unobserve(en.target);
        }
      });
    }, { threshold: 0.25, rootMargin: '0px 0px -8% 0px' });
    tags.forEach(t => io.observe(t));
  }
</script>
