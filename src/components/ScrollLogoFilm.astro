---
// src/components/ScrollLogoFilm.astro
// Apple-style scroll-scrubbed brand film.
// A 120-frame WebP sequence (the BURS mark drawing itself, then folding into
// the hanger) is painted to a <canvas> and scrubbed by scroll position while
// the stage is pinned. Staged copy narrates the three beats: line → hanger →
// brand. Falls back to a static final frame when motion is reduced.

// Poster = the fully-formed mark; the reduced-motion + no-JS fallback.
// The 120-frame sequence itself is referenced in the client script below.
const POSTER = "/assets/logo-seq/frame_120.webp";
---
<section class="film" data-film aria-label="BURS — the mark, drawn">
  <div class="film__stage">
    <canvas class="film__canvas" data-film-canvas aria-hidden="true"></canvas>

    <!-- No-JS / pre-paint fallback: the finished mark -->
    <img class="film__poster" src={POSTER} alt="The BURS mark" decoding="async" />

    <!-- Staged copy ------------------------------------------------------ -->
    <div class="film__copy" aria-hidden="true">
      <p
        class="film__eyebrow"
        data-overlay
        data-in="0.0,0.06" data-out="0.24,0.34"
      >An AI wardrobe stylist</p>

      <!-- Each line pops into the cream around the mark, alternating sides -->
      <h2 class="film__line film__line--left" data-overlay data-in="0.07,0.15" data-out="0.23,0.31"
      >Most of your wardrobe is <em>invisible</em> to you.</h2>

      <h2 class="film__line film__line--right" data-overlay data-in="0.33,0.41" data-out="0.47,0.54"
      >BURS reads the clothes you <em>already own</em>.</h2>

      <h2 class="film__line film__line--left" data-overlay data-in="0.54,0.61" data-out="0.67,0.73"
      >Then the weather, your calendar, your <em>day</em>.</h2>

      <!-- Payoff: the closing line resolves over the formed mark, with one download CTA -->
      <div class="film__final" data-overlay data-in="0.78,0.88">
        <h2 class="film__final-line">And answers in <em>one outfit</em>.</h2>
        <a class="cta cta--ink film__download" href="https://apps.apple.com/app/burs">Get the app <span class="cta__arrow">→</span></a>
      </div>
    </div>

    <!-- Soft cream scrim that strengthens with the closing line for legibility -->
    <div class="film__scrim" data-overlay data-in="0.72,0.85" aria-hidden="true"></div>

    <!-- Opening scroll cue, fades as the film begins -->
    <div class="film__cue" data-overlay data-in="0,0.01" data-out="0.04,0.12" aria-hidden="true">
      <span>SCROLL</span>
      <span class="film__cue-line"></span>
    </div>

    <!-- Closing cue that hands off into the hero -->
    <div class="film__cue film__cue--end" data-overlay data-in="0.93,0.99" aria-hidden="true">
      <span class="film__cue-line"></span>
      <span>CONTINUE</span>
    </div>
  </div>
</section>

<style>
  .film{
    position:relative;
    /* Scroll runway: taller = slower, more deliberate scrub */
    height:340vh;
    background:var(--cream);
  }
  @media (max-width:800px){ .film{ height:260vh } }

  .film__stage{
    position:sticky;
    top:0;
    height:100vh;
    overflow:hidden;
    display:grid;
    place-items:center;
  }

  .film__canvas,
  .film__poster{
    position:absolute;
    inset:0;
    width:100%;
    height:100%;
  }
  .film__canvas{ display:block; background:var(--cream) }
  .film__poster{ object-fit:cover; z-index:0 }
  /* Once JS paints the canvas, it sits above the poster and hides it */
  .film[data-ready] .film__poster{ opacity:0 }
  .film__canvas{ position:relative; z-index:1; opacity:0; transition:opacity .4s ease }
  .film[data-ready] .film__canvas{ opacity:1 }

  /* ---- Copy layer ---- */
  .film__copy{
    position:absolute;
    inset:0;
    z-index:3;
    pointer-events:none;
  }

  .film__eyebrow{
    position:absolute;
    top:clamp(92px,13vh,138px);
    left:50%;
    transform:translate(-50%, var(--lift));
    font-family:var(--mono);
    font-size:11px;
    letter-spacing:.32em;
    text-transform:uppercase;
    color:var(--gold-deep);
  }

  /* Each beat is absolutely placed in the cream beside the centered mark,
     alternating sides; a soft cream halo keeps it legible over the strokes. */
  .film__line{
    position:absolute;
    top:50%;
    transform:translateY(calc(-50% + var(--lift)));
    margin:0;
    font-family:var(--display);
    font-weight:200;
    letter-spacing:-.03em;
    line-height:1.06;
    font-size:clamp(26px,3.3vw,48px);
    color:var(--charcoal);
    max-width:min(30vw,15ch);
    text-wrap:balance;
    text-shadow:0 0 22px var(--cream), 0 0 22px var(--cream), 0 0 64px var(--cream);
  }
  .film__line em{ font-style:italic; color:var(--gold); font-weight:300 }
  .film__line--left{ left:clamp(20px,5vw,76px); text-align:left }
  .film__line--right{ right:clamp(20px,5vw,76px); text-align:right }

  /* Payoff line + the single download CTA, centered low over the formed mark */
  .film__final{
    position:absolute;
    left:50%;
    bottom:clamp(60px,11vh,116px);
    transform:translate(-50%, var(--lift));
    width:min(700px,92vw);
    display:grid;
    justify-items:center;
    gap:30px;
    text-align:center;
  }
  .film__final-line{
    margin:0;
    font-family:var(--display);
    font-weight:200;
    letter-spacing:-.035em;
    line-height:.98;
    font-size:clamp(30px,4.6vw,60px);
    color:var(--charcoal);
    text-wrap:balance;
    max-width:18ch;
  }
  .film__final-line em{ font-style:italic; color:var(--gold); font-weight:300 }

  .film__download{ pointer-events:auto }
  /* Ink download button for the cream film surface */
  .cta--ink{ background:var(--ink); color:var(--cream); border-color:var(--ink) }
  .cta--ink:hover{ background:var(--gold-deep); border-color:var(--gold-deep); color:var(--ink) }

  /* Bottom scrim keeps the closing line legible over the formed mark */
  .film__scrim{
    position:absolute;
    inset:auto 0 0 0;
    height:55%;
    z-index:2;
    background:linear-gradient(180deg,
      rgba(245,240,232,0) 0%,
      rgba(245,240,232,.55) 45%,
      rgba(245,240,232,.92) 100%);
  }

  /* Overlays start hidden; JS drives opacity + lift via scroll */
  [data-overlay]{
    opacity:0;
    --lift:18px;
    will-change:opacity, transform;
  }

  .film__cue{
    position:absolute;
    bottom:40px;left:50%;
    transform:translate(-50%, var(--lift));
    z-index:3;
    display:flex;flex-direction:column;align-items:center;gap:12px;
    font-family:var(--mono);font-size:9px;letter-spacing:.3em;
    color:var(--gold-deep);text-transform:uppercase;
  }
  .film__cue-line{
    width:1px;height:44px;
    background:linear-gradient(180deg,var(--gold) ,transparent);
  }

  @media (prefers-reduced-motion: reduce){
    .film{ height:100vh }
    .film__canvas{ display:none }
    .film[data-ready] .film__poster{ opacity:1 }
    /* Keep positioning transforms; just cancel the reveal lift */
    [data-overlay]{ opacity:1; --lift:0px }
    /* Static fallback shows the formed mark + the payoff line only */
    .film__eyebrow,.film__line,.film__cue{ display:none }
  }
</style>

<script>
  type Overlay = {
    el: HTMLElement;
    inS: number; inE: number;
    outS: number; outE: number;
  };

  const film = document.querySelector<HTMLElement>('[data-film]');
  const canvas = document.querySelector<HTMLCanvasElement>('[data-film-canvas]');

  if (film && canvas) {
    const ctx = canvas.getContext('2d', { alpha: false });
    const FRAME_COUNT = 120;
    const BASE = '/assets/logo-seq/frame_';
    const pad = (n: number) => String(n).padStart(3, '0');

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---- Preload the sequence -------------------------------------------
    const frames: HTMLImageElement[] = [];
    let firstReady = false;
    for (let i = 1; i <= FRAME_COUNT; i++) {
      const img = new Image();
      img.src = `${BASE}${pad(i)}.webp`;
      if (i === 1) {
        img.onload = () => { firstReady = true; film.setAttribute('data-ready', ''); render(); };
      }
      frames.push(img);
    }

    // ---- Canvas sizing (cover) ------------------------------------------
    let dpr = 1, cw = 0, ch = 0;
    function resize() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      cw = canvas!.clientWidth;
      ch = canvas!.clientHeight;
      canvas!.width = Math.round(cw * dpr);
      canvas!.height = Math.round(ch * dpr);
    }

    function paint(idx: number) {
      if (!ctx) return;
      const img = frames[Math.min(FRAME_COUNT - 1, Math.max(0, idx))];
      if (!img || !img.complete || !img.naturalWidth) return;
      const ir = img.naturalWidth / img.naturalHeight;
      const cr = cw / ch;
      let dw: number, dh: number, dx: number, dy: number;
      if (cr > ir) { dw = cw; dh = cw / ir; dx = 0; dy = (ch - dh) / 2; }
      else { dh = ch; dw = ch * ir; dy = 0; dx = (cw - dw) / 2; }
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.fillStyle = '#F5F0E8';
      ctx.fillRect(0, 0, cw, ch);
      ctx.drawImage(img, dx, dy, dw, dh);
    }

    // ---- Overlay copy timeline ------------------------------------------
    const overlays: Overlay[] = Array.from(
      film.querySelectorAll<HTMLElement>('[data-overlay]')
    ).map(el => {
      const [inS, inE] = (el.dataset.in ?? '0,0').split(',').map(Number);
      const [outS, outE] = (el.dataset.out ?? '2,2').split(',').map(Number);
      return { el, inS, inE, outS, outE };
    });

    const ramp = (p: number, a: number, b: number) =>
      b <= a ? (p >= b ? 1 : 0) : Math.min(1, Math.max(0, (p - a) / (b - a)));

    function updateOverlays(p: number) {
      for (const o of overlays) {
        const vis = Math.min(ramp(p, o.inS, o.inE), 1 - ramp(p, o.outS, o.outE));
        o.el.style.opacity = String(vis);
        o.el.style.setProperty('--lift', `${(1 - vis) * 18}px`);
      }
    }

    // ---- Scroll → progress ----------------------------------------------
    let progress = 0;
    function computeProgress() {
      const rect = film!.getBoundingClientRect();
      const total = film!.offsetHeight - window.innerHeight;
      const scrolled = Math.min(Math.max(-rect.top, 0), total);
      return total > 0 ? scrolled / total : 0;
    }

    function render() {
      if (reduced) { resize(); paint(FRAME_COUNT - 1); updateOverlays(1); return; }
      if (!firstReady) return;
      const idx = Math.round(progress * (FRAME_COUNT - 1));
      paint(idx);
      updateOverlays(progress);
    }

    let ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        ticking = false;
        progress = computeProgress();
        render();
      });
    }

    resize();
    if (reduced) {
      render();
    } else {
      progress = computeProgress();
      render();
      window.addEventListener('scroll', onScroll, { passive: true });
    }
    window.addEventListener('resize', () => { resize(); render(); }, { passive: true });
  }
</script>
