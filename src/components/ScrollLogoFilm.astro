---
// src/components/ScrollLogoFilm.astro
// Hero film + scroll-scrubbed brand mark, in one pinned stage.
//   • At rest, the cinematic hero VIDEO plays full-bleed.
//   • As you scroll, the video recedes into the background (fade + blur +
//     push-back) and a 140-frame WebP sequence of the mark drawing itself
//     scrubs up on a <canvas>, narrating the message beat by beat.
//   • It resolves on the clean formed mark with the install CTA (upper-right).
// Falls back to a static poster frame under reduced motion / no-JS.

const HERO_VIDEO = "https://d8j0ntlcm91z4.cloudfront.net/user_39xEmGU99Nuf1tLPDo7HCGecTiT/hf_20260503_095006_fd4e35b8-e575-4e10-9226-e211d064d80c.mp4";

// FRAME_V busts browser/CDN caches when the frames are re-rendered.
const FRAME_V = "5";
const POSTER = `/assets/logo-seq/frame_140.webp?v=${FRAME_V}`;
---
<section class="film" data-film aria-label="BURS — your wardrobe, intelligently styled">
  <div class="film__stage">
    <!-- Hero video — recedes into the background as the animation comes up -->
    <div class="film__video" data-film-video aria-hidden="true">
      <video autoplay muted loop playsinline preload="auto">
        <source src={HERO_VIDEO} type="video/mp4" />
      </video>
      <div class="film__video-veil"></div>
    </div>

    <!-- No-JS / pre-paint fallback: the finished mark -->
    <img class="film__poster" src={POSTER} alt="The BURS mark" decoding="async" />

    <!-- The scrubbed mark -->
    <canvas class="film__canvas" data-film-canvas aria-hidden="true"></canvas>

    <!-- Staged copy ------------------------------------------------------ -->
    <div class="film__copy" aria-hidden="true">
      <!-- Hero title over the video (visible at rest, fades as you scroll) -->
      <div class="film__hero" data-overlay data-in="-1,0" data-out="0.04,0.11">
        <p class="film__hero-eyebrow">An AI wardrobe stylist</p>
        <h2 class="film__hero-title">Your wardrobe, <em>intelligently styled</em>.</h2>
      </div>

      <!-- Each line pops into the cream around the mark, alternating sides -->
      <h2 class="film__line film__line--left" data-overlay data-in="0.22,0.30" data-out="0.40,0.47"
      >Most of your wardrobe is <em>invisible</em> to you.</h2>

      <h2 class="film__line film__line--right" data-overlay data-in="0.46,0.53" data-out="0.60,0.66"
      >BURS reads the clothes you <em>already own</em>.</h2>

      <h2 class="film__line film__line--left" data-overlay data-in="0.62,0.69" data-out="0.78,0.84"
      >Then the weather, your calendar, your <em>day</em>.</h2>

      <!-- Payoff: line above the formed mark, install CTA anchored at the bottom -->
      <h2 class="film__final-line" data-overlay data-in="0.84,0.93"
      >And answers in <em>one outfit</em>.</h2>

      <a class="cta cta--ink film__download" data-overlay data-in="0.89,0.97"
        href="https://apps.apple.com/app/burs">Get the app <span class="cta__arrow">→</span></a>
    </div>

    <!-- Opening scroll cue over the video -->
    <div class="film__cue" data-overlay data-in="-1,0" data-out="0.03,0.09" aria-hidden="true">
      <span>SCROLL</span>
      <span class="film__cue-line"></span>
    </div>
  </div>
</section>

<style>
  .film{
    position:relative;
    /* Scroll runway: video hero + scrub. Taller = more deliberate. */
    height:460vh;
    background:var(--cream);
  }
  @media (max-width:800px){ .film{ height:360vh } }

  .film__stage{
    position:sticky;
    top:0;
    height:100vh;
    overflow:hidden;
  }

  /* ---- Layers ---- */
  .film__video,
  .film__poster,
  .film__canvas{ position:absolute; inset:0; width:100%; height:100% }

  .film__poster{ object-fit:cover; z-index:0 }
  /* No-JS fallback only. Once JS runs, the canvas owns the visuals — hide the
     poster so the finished mark never bleeds through the fading video. */
  .film[data-ready] .film__poster{ opacity:0 }

  .film__video{ z-index:1; background:var(--ink); will-change:opacity, transform, filter }
  .film__video video{ width:100%; height:100%; object-fit:cover; filter:contrast(1.02) saturate(.96) }
  .film__video-veil{
    position:absolute; inset:0; pointer-events:none;
    background:linear-gradient(180deg,
      rgba(14,13,12,.5) 0%, rgba(14,13,12,.12) 32%,
      rgba(14,13,12,.18) 64%, rgba(14,13,12,.6) 100%);
  }

  .film__canvas{ display:block; background:var(--cream); z-index:2; opacity:0 }

  /* ---- Copy layer ---- */
  .film__copy{ position:absolute; inset:0; z-index:4; pointer-events:none }

  /* Hero title (cream, over the video) */
  .film__hero{
    position:absolute;
    left:50%; top:50%;
    transform:translate(-50%, calc(-50% + var(--lift)));
    width:min(960px,92vw);
    text-align:center;
  }
  .film__hero-eyebrow{
    font-family:var(--mono); font-size:11px; letter-spacing:.3em; text-transform:uppercase;
    color:var(--gold-bright); margin-bottom:20px;
  }
  .film__hero-title{
    margin:0; font-family:var(--display); font-weight:200; letter-spacing:-.04em; line-height:.92;
    font-size:clamp(44px,8vw,120px); color:var(--cream); text-wrap:balance;
  }
  .film__hero-title em{ font-style:italic; color:var(--gold-bright); font-weight:300 }

  /* Each beat is placed in the cream beside the centered mark, alternating
     sides; a soft cream halo keeps it legible over the strokes. */
  .film__line{
    position:absolute;
    top:50%;
    transform:translateY(calc(-50% + var(--lift)));
    margin:0;
    font-family:var(--display); font-weight:300; letter-spacing:-.03em; line-height:1.04;
    font-size:clamp(34px,4.7vw,68px);
    color:var(--charcoal);
    max-width:min(40vw,16ch);
    text-wrap:balance;
    /* Strong cream halo so the larger type stays crisp over the strokes */
    text-shadow:0 0 18px var(--cream),0 0 18px var(--cream),0 0 38px var(--cream),0 0 78px var(--cream);
  }
  .film__line em{ font-style:italic; color:var(--gold); font-weight:300 }
  .film__line--left{ left:clamp(20px,5vw,76px); text-align:left }
  .film__line--right{ right:clamp(20px,5vw,76px); text-align:right }

  /* Payoff line — above the formed mark, centered */
  .film__final-line{
    position:absolute;
    top:clamp(72px,10vh,128px);
    left:50%;
    transform:translate(-50%, var(--lift));
    margin:0;
    text-align:center;
    font-family:var(--display); font-weight:300; letter-spacing:-.035em; line-height:1.0;
    font-size:clamp(36px,5.2vw,76px);
    color:var(--charcoal);
    text-wrap:balance;
    max-width:20ch;
    text-shadow:0 0 18px var(--cream),0 0 18px var(--cream),0 0 60px var(--cream);
  }
  .film__final-line em{ font-style:italic; color:var(--gold); font-weight:300 }

  /* Install CTA — anchored at the bottom */
  .film__download{
    position:absolute;
    left:50%;
    bottom:clamp(44px,8vh,86px);
    transform:translate(-50%, var(--lift));
    pointer-events:auto;
  }

  /* Ink download button for the cream film surface */
  .cta--ink{ background:var(--ink); color:var(--cream); border-color:var(--ink) }
  .cta--ink:hover{ background:var(--gold-deep); border-color:var(--gold-deep); color:var(--ink) }

  /* Overlays start hidden; JS drives opacity + lift via scroll */
  [data-overlay]{ opacity:0; --lift:18px; will-change:opacity, transform }

  .film__cue{
    position:absolute;
    bottom:40px; left:50%;
    transform:translate(-50%, var(--lift));
    z-index:4;
    display:flex; flex-direction:column; align-items:center; gap:12px;
    font-family:var(--mono); font-size:9px; letter-spacing:.3em;
    color:rgba(245,240,232,.75); text-transform:uppercase;
  }
  .film__cue-line{ width:1px; height:44px; background:linear-gradient(180deg,rgba(245,240,232,.6),transparent) }

  @media (prefers-reduced-motion: reduce){
    .film{ height:100vh }
    .film__canvas,.film__video{ display:none }
    .film[data-ready] .film__poster{ opacity:1 }
    /* Keep positioning transforms; just cancel the reveal lift */
    [data-overlay]{ opacity:1; --lift:0px }
    /* Static fallback: the formed mark + the payoff/CTA only */
    .film__hero,.film__line,.film__cue{ display:none }
  }
</style>

<script>
  const film = document.querySelector<HTMLElement>('[data-film]');
  const canvas = document.querySelector<HTMLCanvasElement>('[data-film-canvas]');
  const videoWrap = document.querySelector<HTMLElement>('[data-film-video]');

  if (film && canvas) {
    const ctx = canvas.getContext('2d', { alpha: false });
    const FRAME_COUNT = 140;
    const BASE = '/assets/logo-seq/frame_';
    const FRAME_V = '5';
    const pad = (n: number) => String(n).padStart(3, '0');

    // Crossfade band: video → canvas. Before A it's all video; after B all canvas.
    const FADE_A = 0.05, FADE_B = 0.17;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---- Preload the sequence -------------------------------------------
    const frames: HTMLImageElement[] = [];
    let firstReady = false;
    for (let i = 1; i <= FRAME_COUNT; i++) {
      const img = new Image();
      img.src = `${BASE}${pad(i)}.webp?v=${FRAME_V}`;
      if (i === 1) {
        img.onload = () => { firstReady = true; film.setAttribute('data-ready', ''); render(); };
      }
      frames.push(img);
    }

    // ---- Canvas sizing (cover) ------------------------------------------
    let dpr = 1, cw = 0, ch = 0;
    function resize() {
      dpr = Math.min(window.devicePixelRatio || 1, 3);
      cw = canvas!.clientWidth;
      ch = canvas!.clientHeight;
      canvas!.width = Math.round(cw * dpr);
      canvas!.height = Math.round(ch * dpr);
    }

    function paint(idx: number) {
      if (!ctx) return;
      const img = frames[Math.min(FRAME_COUNT - 1, Math.max(0, idx))];
      if (!img || !img.complete || !img.naturalWidth) return;
      const ir = img.naturalWidth / img.naturalHeight;
      const cr = cw / ch;
      // Cover, then scale the mark down a touch so the copy has clearance
      // above and below it.
      const MARK_SCALE = 0.82;
      let dw: number, dh: number;
      if (cr > ir) { dw = cw; dh = cw / ir; }
      else { dh = ch; dw = ch * ir; }
      dw *= MARK_SCALE; dh *= MARK_SCALE;
      const dx = (cw - dw) / 2;
      const dy = (ch - dh) / 2;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.imageSmoothingEnabled = true;
      ctx.imageSmoothingQuality = 'high';
      ctx.fillStyle = '#F5F0E8';
      ctx.fillRect(0, 0, cw, ch);
      ctx.drawImage(img, dx, dy, dw, dh);
    }

    // ---- Overlay copy timeline ------------------------------------------
    type Overlay = { el: HTMLElement; inS: number; inE: number; outS: number; outE: number };
    const overlays: Overlay[] = Array.from(
      film.querySelectorAll<HTMLElement>('[data-overlay]')
    ).map(el => {
      const [inS, inE] = (el.dataset.in ?? '0,0').split(',').map(Number);
      const [outS, outE] = (el.dataset.out ?? '2,2').split(',').map(Number);
      return { el, inS, inE, outS, outE };
    });

    const ramp = (p: number, a: number, b: number) =>
      b <= a ? (p >= b ? 1 : 0) : Math.min(1, Math.max(0, (p - a) / (b - a)));

    function updateOverlays(p: number) {
      for (const o of overlays) {
        const vis = Math.min(ramp(p, o.inS, o.inE), 1 - ramp(p, o.outS, o.outE));
        o.el.style.opacity = String(vis);
        o.el.style.setProperty('--lift', `${(1 - vis) * 18}px`);
      }
    }

    // ---- Scroll → progress ----------------------------------------------
    let progress = 0;
    function computeProgress() {
      const rect = film!.getBoundingClientRect();
      const total = film!.offsetHeight - window.innerHeight;
      const scrolled = Math.min(Math.max(-rect.top, 0), total);
      return total > 0 ? scrolled / total : 0;
    }

    function render() {
      if (reduced) {
        resize();
        paint(FRAME_COUNT - 1);
        canvas!.style.opacity = '1';
        updateOverlays(1);
        return;
      }

      // Video → canvas crossfade
      const mix = ramp(progress, FADE_A, FADE_B);      // 0 = video, 1 = canvas
      if (videoWrap) {
        videoWrap.style.opacity = String(1 - mix);
        videoWrap.style.transform = `scale(${1 + mix * 0.06})`;
        videoWrap.style.filter = `blur(${mix * 4}px)`;
      }
      canvas!.style.opacity = firstReady ? String(mix) : '0';

      // Scrub the sequence over the post-intro range
      if (firstReady) {
        const scrubP = Math.min(1, Math.max(0, (progress - FADE_B) / (1 - FADE_B)));
        paint(Math.round(scrubP * (FRAME_COUNT - 1)));
      }
      updateOverlays(progress);
    }

    let ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        ticking = false;
        progress = computeProgress();
        render();
      });
    }

    resize();
    if (reduced) {
      render();
    } else {
      progress = computeProgress();
      render();
      window.addEventListener('scroll', onScroll, { passive: true });
    }
    window.addEventListener('resize', () => { resize(); render(); }, { passive: true });
  }
</script>
