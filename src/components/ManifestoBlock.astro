---
// Six-sentence manifesto-in-miniature stage. Used on home + manifesto page.
// Each line word-tokenizes at build time so the scroll reveal is purely
// CSS-driven — IntersectionObserver flips one class per line, GPU does the rest.

const lines: string[] = [
  "Most of your wardrobe is *invisible* to you.",
  "Eighty percent of what you own never gets worn.",
  "Not because you don't like it.",
  "Because at 7am you can't see it.",
  "BURS reads what's already there.",
  "The weather, your day, the trip.",
  "And answers in *one* outfit.",
];

type Tok = { word: string; em: boolean };

function tokenize(line: string): Tok[] {
  const out: Tok[] = [];
  // Split on *...* segments while preserving them
  const parts = line.split(/(\*[^*]+\*)/g).filter(Boolean);
  for (const p of parts) {
    const isEm = p.startsWith("*") && p.endsWith("*");
    const text = isEm ? p.slice(1, -1) : p;
    for (const w of text.split(/\s+/).filter(Boolean)) {
      out.push({ word: w, em: isEm });
    }
  }
  return out;
}

const tokenized = lines.map(tokenize);
---

<section class="thesis" data-thesis-section>
  <div class="thesis__atmosphere" aria-hidden="true"></div>

  <div class="wrap thesis__wrap">
    <p class="thesis__eyebrow" data-thesis-reveal>
      <span class="thesis__rule" aria-hidden="true"></span>
      <span class="thesis__eyebrow-text">THE THESIS</span>
    </p>

    <div class="thesis__lines">
      {tokenized.map((toks) => (
        <p class="thesis__line" data-thesis-reveal>
          {toks.map((t, i) => (
            <Fragment>
              <span class="word" style={`--i:${i}`}>
                <span class={`word__inner${t.em ? " word__inner--em" : ""}`}>
                  {t.em ? <em>{t.word}</em> : t.word}
                </span>
              </span>
              {' '}
            </Fragment>
          ))}
        </p>
      ))}
    </div>

    <span class="thesis__signoff" data-thesis-reveal aria-hidden="true">
      <span class="thesis__signoff-rule"></span>
      <span class="thesis__signoff-mark">B</span>
    </span>
  </div>
</section>

<style>
  /* ============================================================
     THE THESIS — letterpress develop reveal
     Strategy:
       • Words tokenized server-side (no JS work in browser)
       • Each word wrapped in a clip-mask; inner span animates
         translateY + rotateX + opacity (GPU-only)
       • IntersectionObserver flips one .in class per element
       • Italic emphasis words arrive last with gold underline
         draw + radial glow — both paint-only (no filters)
  ============================================================ */

  .thesis{
    position:relative;
    background:var(--cream-paper);
    /* Sized to a single screen — all seven statements fit in view */
    min-height:100vh;
    padding-block:clamp(80px, 10vh, 120px);
    display:flex;
    align-items:center;
    overflow:hidden;
  }

  /* Atmospheric backing — dual radial gold washes for depth */
  .thesis__atmosphere{
    position:absolute;inset:0;
    pointer-events:none;
    background:
      radial-gradient(ellipse 55% 45% at 22% 28%, rgba(201,168,108,.10), transparent 70%),
      radial-gradient(ellipse 50% 40% at 82% 78%, rgba(201,168,108,.08), transparent 70%);
  }

  .thesis__wrap{position:relative;z-index:1;width:100%}

  /* ---------- Eyebrow ----------
     A serial-printer reveal: short rule extends, letters condense
     from spread → tight while fading in. */
  .thesis__eyebrow{
    display:inline-flex;
    align-items:center;
    gap:14px;
    font-family:var(--mono);
    font-size:11px;
    letter-spacing:.26em;
    text-transform:uppercase;
    color:var(--gold-deep);
    margin-bottom:clamp(28px, 4vh, 48px);
    /* container fades as a whole */
    opacity:0;
    transition:opacity .9s var(--eo) .05s;
  }
  .thesis__eyebrow.in{opacity:1}

  .thesis__rule{
    display:block;
    width:0;height:1px;
    background:currentColor;
    opacity:.55;
    transform-origin:left center;
    transition:width 1.05s cubic-bezier(.2,.65,.12,1) .15s;
  }
  .thesis__eyebrow.in .thesis__rule{width:36px}

  .thesis__eyebrow-text{
    display:inline-block;
    letter-spacing:.62em;
    transform:translateX(8px);
    transition:
      letter-spacing 1.2s cubic-bezier(.2,.65,.12,1) .18s,
      transform 1.2s cubic-bezier(.2,.65,.12,1) .18s;
    /* Avoid right-edge clipping when over-spaced */
    padding-right:.62em;
  }
  .thesis__eyebrow.in .thesis__eyebrow-text{
    letter-spacing:.26em;
    transform:translateX(0);
  }

  /* ---------- Lines ---------- */
  .thesis__lines{
    /* 3D parent — each word's rotateX needs perspective from somewhere
       above it; one declaration here covers all descendants */
    perspective:1200px;
    perspective-origin:50% 0%;
  }

  .thesis__line{
    font-family:var(--display);
    font-weight:200;
    /* Smaller — all 7 lines must fit in a single viewport */
    font-size:clamp(20px, 2.4vw, 34px);
    line-height:1.2;
    letter-spacing:-.02em;
    color:var(--charcoal);
    max-width:min(60ch, 96%);
    /* Tight vertical rhythm — keeps the column compact */
    margin-bottom:clamp(8px, 1vh, 14px);
    text-wrap:balance;
  }
  .thesis__line:last-child{margin-bottom:0}

  /* Each word — horizontal clip-mask that sweeps left → right,
     revealing the type as if it were being written across the page.
     Negative left/right insets give italic glyphs slack so they
     aren't cropped at their slanted overhangs. */
  .thesis__line .word{
    display:inline-block;
    vertical-align:baseline;
    padding:.06em 0 .16em;
    line-height:1;
    /* Hidden state: clip everything from the right edge inward */
    clip-path:inset(-.08em 102% -.02em -.06em);
    transition:clip-path 1.1s cubic-bezier(.62,.02,.18,1);
    transition-delay:calc(var(--i, 0) * 48ms);
  }
  .thesis__line.in .word{
    /* Revealed: clip retracts past the right edge, leaving italic slack */
    clip-path:inset(-.08em -.35em -.02em -.06em);
  }

  /* Inner span: subtle horizontal slide + opacity for warmth on top
     of the mask — gives the words weight as they come in instead of
     just appearing. Pure paint props, no layout cost. */
  .thesis__line .word__inner{
    display:inline-block;
    line-height:1.12;
    transform:translateX(-.18em);
    opacity:.4;
    transition:
      transform 1.1s cubic-bezier(.62,.02,.18,1),
      opacity .85s ease-out;
    transition-delay:calc(var(--i, 0) * 48ms);
  }
  .thesis__line.in .word__inner{
    transform:translateX(0);
    opacity:1;
  }

  /* ---------- Italic emphasis words (the conviction beats) ----------
     Same horizontal sweep as siblings, but with extra delay so they
     arrive AFTER their neighbors and a gold underline draws across
     once the word has fully revealed. */
  .thesis__line .word__inner--em{
    color:var(--gold-deep);
    font-weight:300;
    position:relative;
    /* Push reveal so emphasis lands AFTER surrounding line — eye-catching */
    transition-delay:calc(var(--i, 0) * 48ms + 280ms);
  }
  .thesis__line .word__inner--em em{
    font-style:italic;
    font-weight:300;
  }
  /* The mask on the parent .word also needs the matching delay so the
     reveal stays in sync with the inner. */
  .thesis__line .word:has(.word__inner--em){
    transition-delay:calc(var(--i, 0) * 48ms + 280ms);
  }

  /* (Per-italic underline removed — the line-wide hand-drawn squiggle
     passes beneath every word including italic emphasis, so a separate
     underline on em words would just stack visually. Gold color + italic
     still distinguishes the conviction beats within the line.) */

  /* ---------- Signoff mark — small "B" monogram + rule ---------- */
  .thesis__signoff{
    display:flex;align-items:center;gap:18px;
    margin-top:clamp(28px, 4vh, 48px);
    opacity:0;
    transition:opacity 1.2s ease .35s;
  }
  .thesis__signoff.in{opacity:1}

  .thesis__signoff-rule{
    display:block;
    width:0;height:1px;
    background:rgba(28,25,23,.25);
    transition:width 1.4s cubic-bezier(.2,.65,.12,1) .4s;
  }
  .thesis__signoff.in .thesis__signoff-rule{width:clamp(48px, 6vw, 96px)}

  .thesis__signoff-mark{
    font-family:var(--display);
    font-style:italic;
    font-weight:300;
    font-size:18px;
    color:var(--gold-deep);
    letter-spacing:.02em;
    transform:translateX(-6px);
    opacity:0;
    transition:
      transform 1.1s cubic-bezier(.2,.65,.12,1) .55s,
      opacity .9s ease .55s;
  }
  .thesis__signoff.in .thesis__signoff-mark{
    transform:translateX(0);
    opacity:.85;
  }

  /* ---------- Reduced motion: collapse all reveals ---------- */
  @media (prefers-reduced-motion: reduce){
    .thesis__eyebrow,
    .thesis__rule,
    .thesis__eyebrow-text,
    .thesis__line .word,
    .thesis__line .word__inner,
    .thesis__signoff,
    .thesis__signoff-rule,
    .thesis__signoff-mark{
      transition:none !important;
      transform:none !important;
      opacity:1 !important;
    }
    .thesis__rule{width:36px}
    .thesis__eyebrow-text{letter-spacing:.26em}
    .thesis__signoff-rule{width:64px}
    .thesis__signoff-mark{opacity:.85}
  }
</style>

<script>
  /* Lightweight reveal — observes once, never re-fires.
     We watch each [data-thesis-reveal] independently so each line
     wakes up the moment IT crosses the threshold, not the section. */

  const targets = document.querySelectorAll<HTMLElement>('[data-thesis-reveal]');
  if (targets.length) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduce) {
      // Honor preference instantly — no animation, no observer overhead.
      targets.forEach((el) => el.classList.add('in'));
    } else {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          const el = e.target as HTMLElement;
          el.classList.add('in');
          io.unobserve(el);

          // Strip will-change after the longest possible animation
          // window completes — keeps the compositor lean afterward.
          window.setTimeout(() => {
            el.querySelectorAll<HTMLElement>('.word__inner').forEach((w) => {
              w.style.willChange = 'auto';
            });
          }, 2400);
        }
      }, {
        // Fire when the line is comfortably in view (15% above bottom)
        rootMargin: '0px 0px -12% 0px',
        threshold: 0,
      });

      targets.forEach((el) => io.observe(el));
    }
  }
</script>
