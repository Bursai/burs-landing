---
// src/components/ActsPlates.astro
// The app in five acts — Editorial Plates.
// A pinned stage; the five app screens hang as matted exhibition plates on
// a wall that glides horizontally as you scroll. The plate crossing the
// center line sharpens to full size while its caption trades in at the
// lower-left and a counter ticks 01–05.
interface Act {
  index: number;
  numeral: string;
  eyebrow: string;
  headline: string;
  lede: string;
  image: string;
  imageAlt: string;
}

const acts: Act[] = [
  {
    index: 1,
    numeral: "I",
    eyebrow: "ONE — THE CLOSET, READ",
    headline: "A stylist who's memorised your closet.",
    lede: "Every outfit, built from what you already own. Styled for the weather, the occasion, and you.",
    image: "/assets/act-i-wardrobe-screen.jpeg?v=2",
    imageAlt: "BURS wardrobe scan in progress, displaying tagged garments"
  },
  {
    index: 2,
    numeral: "II",
    eyebrow: "TWO — THE DAY, UNDERSTOOD",
    headline: "The weather. Your day. <em>Yesterday's</em> outfit.",
    lede: "Before BURS recommends anything, it reads the weather, your calendar, your location, and yesterday's outfit. The day, understood.",
    image: "/assets/act-ii-context-screen.jpeg?v=2",
    imageAlt: "BURS reading the day's context: weather, calendar, location"
  },
  {
    index: 3,
    numeral: "III",
    eyebrow: "THREE — TALK TO IT",
    headline: "A stylist that <em>refines</em> in a sentence.",
    lede: "Ask in plain language. The stylist answers using pieces already in your wardrobe.",
    image: "/assets/act-iii-stylist-screen.jpeg?v=2",
    imageAlt: "BURS AI stylist chat showing outfit refinements"
  },
  {
    index: 4,
    numeral: "IV",
    eyebrow: "FOUR — THE WEEK, DRAFTED",
    headline: "Monday's pitch. Thursday's dinner. <em>Saturday's</em> off-site.",
    lede: "Sync your calendar and BURS drafts an outfit for every event. Swap any piece with one tap.",
    image: "/assets/act-iv-week-screen.jpeg?v=2",
    imageAlt: "BURS week planner showing outfits for Monday through Sunday"
  },
  {
    index: 5,
    numeral: "V",
    eyebrow: "FIVE — THE TRIP, PACKED",
    headline: "Pack a city in <em>twelve</em> pieces.",
    lede: "Tell BURS where you're going and for how long. It builds a minimum-viable capsule from your wardrobe — every piece earning its place, every outfit pre-imagined.",
    image: "/assets/act-v-travel-screen.jpeg?v=2",
    imageAlt: "BURS travel capsule builder showing 12-piece capsule for a 4-day trip"
  }
];
---
<section class="plates" data-plates aria-label="The BURS app in five acts">
  <div class="plates__stage">
    <div class="plates__head wrap">
      <p class="eyebrow">THE APP — IN FIVE ACTS</p>
      <p class="plates__counter"><span data-plates-counter>01</span> — 05</p>
    </div>

    <div class="plates__track" data-plates-track>
      {acts.map((a, i) => (
        <figure class="plate" data-plate={a.index} class:list={[i === 0 && "is-on"]}>
          <figcaption class="plate__mat-head">
            <span class="plate__numeral">{a.numeral}</span>
            <span class="plate__label">{a.eyebrow}</span>
          </figcaption>
          <div class="plate__img">
            <img
              src={a.image}
              alt={a.imageAlt}
              loading={i === 0 ? "eager" : "lazy"}
              decoding="async"
            />
          </div>
        </figure>
      ))}
    </div>

    <div class="plates__copy wrap">
      {acts.map((a, i) => (
        <div class="plates__cap" data-plate-copy={a.index} class:list={[i === 0 && "is-on"]}>
          <h2 set:html={a.headline} />
          <p class="lede">{a.lede}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .plates{ height: 460vh; background: var(--cream); position: relative }
  .plates__stage{
    position: sticky; top: 0; height: 100vh; overflow: hidden;
    display: flex; flex-direction: column; justify-content: center;
  }

  .plates__head{
    position: absolute; top: clamp(20px, 4vh, 44px); left: 0; right: 0;
    display: flex; justify-content: space-between; align-items: baseline;
  }
  .plates__head .eyebrow{ color: var(--gold-deep) }
  .plates__counter{ font-family: var(--mono); font-size: 11px; letter-spacing: .3em; color: var(--charcoal-2) }
  .plates__counter span{ color: var(--gold-deep) }

  .plates__track{
    display: flex; align-items: center;
    gap: clamp(36px, 5vw, 96px);
    padding-inline: 50vw;             /* room for the end plates to center */
    width: max-content;
    will-change: transform;
  }

  .plate{
    margin: 0;
    background: var(--cream-paper);
    border: 1px solid rgba(28,25,23,.14);
    box-shadow: 0 30px 60px -28px rgba(14,13,12,.4);
    padding: clamp(12px, 1.4vw, 20px);
    transition: transform .5s var(--eo), opacity .5s var(--eo);
    transform: scale(.93);
    opacity: .55;
  }
  .plate.is-on{ transform: scale(1); opacity: 1 }

  .plate__mat-head{
    display: flex; align-items: baseline; justify-content: space-between; gap: 18px;
    padding: 2px 4px 12px;
  }
  .plate__numeral{
    font-family: var(--display); font-weight: 200; font-style: italic;
    font-size: 26px; color: var(--gold-deep); line-height: 1;
  }
  .plate__label{
    font-family: var(--mono); font-size: 9px; letter-spacing: .25em;
    text-transform: uppercase; color: var(--charcoal-2);
  }
  .plate__img{
    height: min(56vh, 560px);
    aspect-ratio: 1320 / 2868;
    overflow: hidden;
    border: 1px solid rgba(28,25,23,.18);
  }
  .plate__img img{ width: 100%; height: 100%; object-fit: cover; display: block }

  .plates__copy{
    position: absolute; left: 0; right: 0;
    bottom: clamp(22px, 5vh, 56px);
    pointer-events: none;
  }
  .plates__cap{
    position: absolute; bottom: 0; left: var(--gutter);
    max-width: 44ch;
    opacity: 0; transform: translateY(14px);
    transition: opacity .45s var(--eo), transform .45s var(--eo);
  }
  .plates__cap.is-on{ opacity: 1; transform: translateY(0) }
  .plates__cap h2{
    margin: 0;
    font-family: var(--display); font-weight: 300; letter-spacing: -.03em; line-height: 1.02;
    font-size: clamp(26px, 2.9vw, 44px); color: var(--charcoal); text-wrap: balance;
    /* Cream halo keeps the line crisp if it crosses a plate edge */
    text-shadow: 0 0 16px var(--cream), 0 0 16px var(--cream), 0 0 36px var(--cream);
  }
  .plates__cap h2 :global(em){ font-style: italic; color: var(--gold) }
  .plates__cap .lede{
    margin-top: 10px;
    font-family: var(--serif); font-style: italic;
    font-size: 15px; line-height: 1.5; color: var(--charcoal-2);
    max-width: 50ch;
    text-shadow: 0 0 14px var(--cream), 0 0 14px var(--cream);
  }

  @media (max-width: 700px){
    /* Lift the wall so the caption has clean floor space */
    .plates__stage{ padding-bottom: 16vh }
    .plate__img{ height: 48vh }
    .plates__cap h2{ font-size: 24px }
    .plates__cap .lede{ font-size: 14px }
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>('[data-plates]');
  const track = document.querySelector<HTMLElement>('[data-plates-track]');
  const counter = document.querySelector<HTMLElement>('[data-plates-counter]');
  const plates = [...document.querySelectorAll<HTMLElement>('[data-plate]')];
  const caps = [...document.querySelectorAll<HTMLElement>('[data-plate-copy]')];

  if (section && track && plates.length) {
    // Warm the screens one viewport ahead so no plate glides in half-loaded.
    const warm = new IntersectionObserver((entries, obs) => {
      if (!entries.some(en => en.isIntersecting)) return;
      obs.disconnect();
      track.querySelectorAll('img').forEach(img => {
        img.loading = 'eager';
        img.decode?.().catch(() => {});
      });
    }, { rootMargin: '100% 0px' });
    warm.observe(section);

    let active = '1';

    const render = () => {
      const total = section.offsetHeight - window.innerHeight;
      const p = total > 0 ? Math.min(1, Math.max(0, -section.getBoundingClientRect().top / total)) : 0;

      // Glide the wall so the first and last plates land exactly on the
      // center line at the runway's endpoints.
      const mid = window.innerWidth / 2;
      const first = plates[0], last = plates[plates.length - 1];
      const c0 = first.offsetLeft + first.offsetWidth / 2;
      const c1 = last.offsetLeft + last.offsetWidth / 2;
      const x = c0 + (c1 - c0) * p - mid;
      track.style.transform = `translate3d(${-x}px,0,0)`;

      // Active plate = the one nearest the center line
      let best = active, bestD = Infinity;
      plates.forEach(pl => {
        const r = pl.getBoundingClientRect();
        const d = Math.abs((r.left + r.right) / 2 - mid);
        if (d < bestD) { bestD = d; best = pl.dataset.plate!; }
      });
      if (best !== active) {
        active = best;
        if (counter) counter.textContent = active.padStart(2, '0');
      }
      plates.forEach(pl => pl.classList.toggle('is-on', pl.dataset.plate === active));
      caps.forEach(c => c.classList.toggle('is-on', c.dataset.plateCopy === active));
    };

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { ticking = false; render(); });
    };

    render();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
  }
</script>
