---
// src/components/ScrollThread.astro
// The continuous "single line" — a drawn gold thread down the left margin
// that fills with overall scroll progress, carrying the film's
// "Drawn from a single line." motif through the whole page. Decorative;
// fades in once past the opening film and hides on small screens.
interface Props {
  /** Section labels, top → bottom, shown as nodes along the thread. */
  nodes?: string[];
}
const { nodes = ["Thesis", "The closet", "What it's not", "Pricing"] } = Astro.props;
---
<aside class="thread" data-thread aria-hidden="true">
  <div class="thread__rail">
    <span class="thread__track"></span>
    <span class="thread__fill" data-thread-fill></span>
    <ul class="thread__nodes">
      {nodes.map((label, i) => (
        <li class="thread__node" style={`--at:${nodes.length > 1 ? i / (nodes.length - 1) : 0}`}>
          <span class="thread__dot"></span>
          <span class="thread__label">{label}</span>
        </li>
      ))}
    </ul>
  </div>
</aside>

<style>
  .thread{
    position:fixed;
    left:max(calc(var(--gutter) - 6px), 18px);
    top:0;
    height:100vh;
    z-index:40;
    pointer-events:none;
    display:flex;
    align-items:center;
    /* Hidden until the film hands off */
    opacity:0;
    transition:opacity .6s var(--eo);
  }
  .thread.is-live{ opacity:1 }

  .thread__rail{
    position:relative;
    height:min(58vh, 520px);
    width:1px;
  }
  .thread__track{
    position:absolute;
    inset:0;
    width:1px;
    background:rgba(28,25,23,.14);
  }
  .thread__fill{
    position:absolute;
    top:0;left:0;
    width:1px;
    height:0%;
    background:linear-gradient(180deg,var(--gold-deep),var(--gold));
    box-shadow:0 0 8px rgba(201,168,108,.45);
    will-change:height;
  }

  .thread__nodes{
    position:absolute;
    inset:0;
    list-style:none;
    margin:0;padding:0;
  }
  .thread__node{
    position:absolute;
    left:0;
    top:calc(var(--at) * 100%);
    transform:translate(-50%,-50%);
    display:flex;
    align-items:center;
    gap:10px;
  }
  .thread__dot{
    width:6px;height:6px;
    border-radius:50%;
    background:var(--cream);
    border:1px solid rgba(28,25,23,.28);
    transition:background .35s var(--eo), border-color .35s var(--eo), box-shadow .35s var(--eo), transform .35s var(--eo);
  }
  .thread__node.is-on .thread__dot{
    background:var(--gold);
    border-color:var(--gold-deep);
    box-shadow:0 0 10px rgba(201,168,108,.6);
    transform:scale(1.15);
  }
  .thread__label{
    font-family:var(--mono);
    font-size:9px;
    letter-spacing:.24em;
    text-transform:uppercase;
    color:rgba(28,25,23,.42);
    white-space:nowrap;
    opacity:0;
    transform:translateX(-4px);
    transition:opacity .35s var(--eo), transform .35s var(--eo), color .35s var(--eo);
  }
  .thread__node.is-on .thread__label{
    opacity:1;
    transform:translateX(0);
    color:var(--gold-deep);
  }

  @media (max-width:1024px){ .thread{ display:none } }
  @media (prefers-reduced-motion: reduce){
    .thread__fill{ transition:none }
    .thread{ transition:none }
  }
</style>

<script>
  const thread = document.querySelector<HTMLElement>('[data-thread]');
  const fill = document.querySelector<HTMLElement>('[data-thread-fill]');
  const nodes = Array.from(document.querySelectorAll<HTMLElement>('.thread__node'));

  if (thread && fill) {
    let ticking = false;

    const update = () => {
      ticking = false;
      const doc = document.documentElement;
      const max = doc.scrollHeight - window.innerHeight;
      const p = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;

      fill.style.height = `${p * 100}%`;

      // The thread wakes once the opening film has handed off (~1 viewport in)
      thread.classList.toggle('is-live', window.scrollY > window.innerHeight * 0.8);

      // Light each node as the fill passes it
      for (const n of nodes) {
        const at = parseFloat(n.style.getPropertyValue('--at')) || 0;
        n.classList.toggle('is-on', p >= at - 0.001);
      }
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }
</script>
